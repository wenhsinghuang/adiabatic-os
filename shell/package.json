{
  "name": "@adiabatic/shell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:electron",
    "build:electron": "node ../scripts/build-electron-main.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron": "npm run build:electron && electron .",
    "electron:dev": "npm run build:electron && NODE_ENV=development electron ."
  },
  "dependencies": {
    "@mdxeditor/editor": "^4.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@webcontainer/api": "^1.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "monaco-editor": "^0.52.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
